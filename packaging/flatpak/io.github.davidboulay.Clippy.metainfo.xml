  <project_license>MIT</project_license>
  <name>Clippy</name>
  <summary>Clipboard history panel for Wayland</summary>
  <developer id="io.github.davidboulay">
    <name>David Boulay</name>
  </developer>
  <description>
    <p>
      Clippy shows a Paste-style strip of recent clipboard items (text and
      images) at the bottom of the screen, toggled by a global shortcut.
    </p>
    <p>Features:</p>
    <ul>
      <li>Text and image clipboard history with pinning and search</li>
      <li>Follows the COSMIC light/dark theme</li>
      <li>System-tray icon; never shown in the dock</li>
      <li>History retention, copy sound, and paste-as-plain-text options</li>
      <li>Right-click a tile for per-item actions (incl. copy as plain text)</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.davidboulay.Clippy.desktop</launchable>
